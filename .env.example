# Azure AD Configuration
APPSETTING_AAD_ApplicationId="your-azure-ad-app-id"
APPSETTING_AAD_ApplicationSecret="your-azure-ad-app-secret"
APPSETTING_AAD_BaseUri="https://your-domain.com"

# Azure OpenAI Configuration
APPSETTING_AZURE_OPENAI_KEY="your-azure-openai-key"
APPSETTING_AZURE_OPENAI_ENDPOINT="https://your-openai-endpoint.openai.azure.com/"

# Session Configuration
APPSETTING_SessionSecret="your-session-secret"

# Slack Configuration (Optional)
APPSETTING_SLACK_BotToken="xoxb-your-slack-bot-token"
APPSETTING_SLACK_SigningSecret="your-slack-signing-secret"

# MongoDB Configuration
SQLCONNSTR_DbUri="mongodb://your-mongodb-uri"
SQLCONNSTR_DbUsername="your-mongodb-username"
SQLCONNSTR_DbPassword="your-mongodb-password"

# Application Insights (Optional)
APPINSIGHTS_INSTRUMENTATIONKEY="your-app-insights-key"

# ChatGPT App Configuration (Apps SDK with MCP Server)
APPSETTING_CHATGPT_APP_API_KEY="tm_your_generated_api_key_here"
